    folderPath = gBasExportPath
    outputFile = folderPath & "ALL_IN_ONE.bas"
    
    outNo = FreeFile
    Open outputFile For Output As #outNo
    
    '==============================
    ' ■ 先頭
    '==============================
    
    Print #outNo, ""
    Print #outNo, vbCrLf
    
    '==============================
    ' ■ A：Entry系
    '==============================
    
    Call AppendGroup(outNo, folderPath, True)
    
    '==============================
    ' ■ B：その他
    '==============================
    
    Call AppendGroup(outNo, folderPath, False)
    
    Close #outNo
    
    MsgBox "完了"

