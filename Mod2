'==============================


Sub GetQueryResults_local( _
    SqlQuery As String, _
    WorkBookName As String, _
    WorkSheetName As String)

    Dim DataFilePath As String
    Dim cn As ADODB.Connection
    Dim rs As ADODB.Recordset
    Dim ws As Worksheet
    Dim RowCount As Long
    Dim ColCount As Long
    Dim i As Long

    If SqlQuery = "" Then
        Debug.Print "SQL_ERR: Query string missing"
        Exit Sub
    End If

    DataFilePath = WorkBookName

    If Dir(DataFilePath) = "" Then
        Debug.Print "SQL_ERR: File not found - " & DataFilePath
        Exit Sub
    End If

    Set cn = New ADODB.Connection

    cn.ConnectionString = _
        "Provider=Microsoft.ACE.OLEDB.12.0;" & _
        "Data Source=" & DataFilePath & ";" & _
        "Extended Properties=""Excel 12.0 Xml;HDR=YES"";"

    On Error GoTo EndPoint
    cn.Open

    On Error GoTo CloseConnection

    Set rs = New ADODB.Recordset
    rs.ActiveConnection = cn
    rs.CursorType = adOpenStatic
    rs.Source = SqlQuery
    rs.Open

    On Error GoTo CloseRecordset

    RowCount = rs.RecordCount
    If RowCount = 0 Then
        Debug.Print "SQL_ERR: No results"
        GoTo SafeExit
    End If

    ColCount = rs.Fields.Count

    Set ws = Workbooks(Dir(WorkBookName)).Worksheets(WorkSheetName)
    ws.Cells.Clear

    ' ヘッダー出力
    For i = 0 To ColCount - 1
        ws.Cells(1, i + 1).Value = rs.Fields(i).name
    Next i

    ' データ出力
    ws.Cells(2, 1).CopyFromRecordset rs
    ws.Columns.AutoFit

SafeExit:
    rs.Close
    cn.Close
    Set rs = Nothing
    Set cn = Nothing
    Exit Sub

'---------------------------
' ERROR HANDLERS
'---------------------------

CloseRecordset:
    rs.Close
    cn.Close
    Debug.Print "SQL_ERR after recordset open"
    Debug.Print Err.Number, Err.Description
    Exit Sub

CloseConnection:
    cn.Close
    Debug.Print "SQL_ERR after connection open"
    Debug.Print Err.Number, Err.Description
    Exit Sub

EndPoint:
    Debug.Print "SQL_ERR: Connection failed"
    Debug.Print Err.Number, Err.Description

End Sub


