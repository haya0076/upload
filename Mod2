' [DEF] キーワード抽出（１：ファイル名　２：行番号　３：コード尾　４：DEFコメント）
Sub ExtractFromFile_WithDEF(inptPattern As String, inptSheet As String)

    Dim filePath As Variant
    Dim lineText As String
    Dim lineNo As Long
    Dim fileName As String
    
    Dim regEx As Object
    Dim ts As Object
    Dim fso As Object

    Dim ws As Worksheet
    Set ws = Workbooks(p_wbName_main()).Sheets(inptSheet)

    ws.Cells.Clear

    ' ヘッダ
    ws.Cells(1, 1) = "File"
    ws.Cells(1, 2) = "Line"
    ws.Cells(1, 3) = "Code"
    ws.Cells(1, 4) = "DEF"

    Dim outputRow As Long
    outputRow = 2

    ' 正規表現（関数検出）
    Set regEx = CreateObject("VBScript.RegExp")
    regEx.pattern = inptPattern
    regEx.IgnoreCase = True

    Set fso = CreateObject("Scripting.FileSystemObject")

    With Application.FileDialog(msoFileDialogFilePicker)
        .AllowMultiSelect = True
        If .Show <> -1 Then Exit Sub

        For Each filePath In .SelectedItems
            
            Set ts = fso.OpenTextFile(filePath, 1)
            fileName = fso.GetFileName(filePath)
            
            lineNo = 0
            
            Dim defBuffer As String
            defBuffer = ""
            
            Do While Not ts.AtEndOfStream
                
                lineText = ts.ReadLine
                lineNo = lineNo + 1

                ' --- DEF検出 ---
                If InStr(lineText, "[DEF]") > 0 Then
                    defBuffer = Trim(Replace(lineText, "'", "")) ' コメント記号除去
                    GoTo ContinueLoop
                End If

                ' --- 関数検出 ---
                If regEx.test(lineText) Then
                    
                    ws.Cells(outputRow, 1).Value = fileName
                    ws.Cells(outputRow, 2).Value = lineNo
                    ws.Cells(outputRow, 3).Value = lineText
                    ws.Cells(outputRow, 4).Value = defBuffer
                    
                    outputRow = outputRow + 1
                    
                    defBuffer = ""
                    
                End If

ContinueLoop:
            Loop

            ts.Close

        Next filePath
    End With

    MsgBox "抽出完了：" & outputRow - 2 & "件"

End Sub


'改良版 ※シートクリア処理等はしていない
Sub ListFunctions_Final()

    Dim folderPath As String
    Dim fileName As String
    Dim filePath As String
    Dim lineText As String
    Dim logicalLine As String
    Dim fileNo As Integer
    Dim row As Long
    
    Dim fncComment As String
    
    folderPath = gBasExportPath
    row = 1
    
    ' 見出し
    Cells(row, 1).Value = "ファイル"
    Cells(row, 2).Value = "名称"
    Cells(row, 3).Value = "機能"
    Cells(row, 4).Value = "定義"
    row = row + 1
    
    fileName = Dir(folderPath & "*.bas")
    
    Do While fileName <> ""
        
        filePath = folderPath & fileName
        fileNo = FreeFile
        
        Open filePath For Input As #fileNo
        
        logicalLine = ""
        fncComment = ""
        
        Do Until EOF(fileNo)
            Line Input #fileNo, lineText
            
            ' =========================
            ' ■ コメントタグ取得
            ' =========================
            If Left(Trim(lineText), 1) = "'" Then
                If InStr(LCase(lineText), "[fnc]") > 0 Then
                    fncComment = Replace(lineText, "'", "")
                    fncComment = Trim(fncComment)
                End If
            End If
            
            ' =========================
            ' ■ 改行結合
            ' =========================
            If Right(Trim(lineText), 1) = "_" Then
                logicalLine = logicalLine & " " & _
                              Left(Trim(lineText), Len(Trim(lineText)) - 1)
            Else
                logicalLine = logicalLine & " " & Trim(lineText)
                
                ' =========================
                ' ■ 判定処理
                ' =========================
                Call CheckAndOutput(logicalLine, fileName, fncComment, row)
                
                logicalLine = ""
            End If
            
        Loop
        
        Close #fileNo
        fileName = Dir
        
    Loop
    
    MsgBox "一覧作成完了"

End Sub


Sub CheckAndOutput(ByVal logicalLine As String, _
                   ByVal fileName As String, _
                   ByRef fncComment As String, _
                   ByRef row As Long)

    Dim lineCheck As String
    lineCheck = LCase(Trim(logicalLine))
    
    ' コメント行はスキップ（タグは事前取得済み）
    If Left(lineCheck, 1) = "'" Then Exit Sub
    
    ' ノイズ除外
'    If lineCheck Like "end *" Then Exit Sub
'    If lineCheck Like "exit *" Then Exit Sub
'    If InStr(lineCheck, "declare") > 0 Then Exit Sub
    
    If lineCheck Like "function *" _
    Or lineCheck Like "sub *" _
    Or lineCheck Like "public function *" _
    Or lineCheck Like "public sub *" _
    Or lineCheck Like "private function *" _
    Or lineCheck Like "private sub *" Then
    Else
        Exit Sub
    End If
    
    ' =========================
    ' ■ 関数・Sub判定（柔軟）
    ' =========================
    If lineCheck Like "*function*" Or lineCheck Like "*sub*" Then
        
        ' "("がある＝定義っぽい
        If InStr(lineCheck, "(") > 0 Then
            
            Cells(row, 1).Value = fileName
            Cells(row, 2).Value = ExtractName(lineCheck)
            Cells(row, 3).Value = fncComment
            Cells(row, 4).Value = logicalLine
            
            row = row + 1
            fncComment = ""
            
        End If
        
    End If

End Sub

Function ExtractName(lineText As String) As String

    Dim temp As String
    temp = lineText
    
    If InStr(temp, "function") > 0 Then
        temp = Split(temp, "function")(1)
    ElseIf InStr(temp, "sub") > 0 Then
        temp = Split(temp, "sub")(1)
    End If
    
    temp = Trim(temp)
    ExtractName = Split(temp, "(")(0)

End Function


