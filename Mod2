 Sub ReplaceSheetLinkText(oldName As String, newName As String)

    Dim ws As Worksheet
    Dim cell As Range

    For Each ws In ActiveWorkbook.Sheets
        For Each cell In ws.UsedRange.Cells
            If Not IsError(cell.Value) Then
                If InStr(cell.Value, "L[" & oldName & "]") > 0 Then
                    cell.Value = Replace(cell.Value, _
                        "L[" & oldName & "]", _
                        "L[" & newName & "]")
                End If
            End If
        Next cell
    Next ws

End Sub

' シート上のM[]を探す
Sub ExtractMTags()

    Dim ws As Worksheet
    Dim rng As Range
    Dim cell As Range
    Dim regEx As Object
    Dim matches As Object
    Dim match As Object
    Dim row As Long
    
    For Each ws In ActiveWorkbook.Worksheets
        Set rng = ws.UsedRange
        
        Set regEx = CreateObject("VBScript.RegExp")
        
        With regEx
            .pattern = "M\[[^\]]+\]"
            .Global = True
        End With
        
        row = 1
        
        For Each cell In rng
        
            If Not IsError(cell.Value) Then
            
                If Len(cell.Value) > 0 Then
                    
                    If regEx.test(cell.Value) Then
                        
                        Set matches = regEx.Execute(cell.Value)
                        
                        For Each match In matches
                            Cells(row, 10).Value = match.Value ' 出力列
                            row = row + 1
                        Next
                        
                    End If
                    
                End If
                
            End If
            
        Next
    Next ws
    
    MsgBox "抽出完了"

End Sub

