    Dim ws As Worksheet
    
    On Error Resume Next
    Set ws = wb.Sheets(shtName)
    SheetExists = Not ws Is Nothing
    On Error GoTo 0
End Function


' [DEF] [L[]] シートの存在を確認
Function GetSheetName_JumpOrCreateSheetFromLink() As String
    Dim startPos As Long
    Dim endPos As Long
    Dim sheetName As String
    Dim strResult As String
    Dim ws As Worksheet
    
    strResult = ""

    Dim cellText As String
    cellText = Trim(ActiveCell.Value)
    
    If Left(cellText, 2) <> "L[" Then
        GetSheetName_JumpOrCreateSheetFromLink = ""
        Application.StatusBar = "[L[]形式が必要です]"
        Exit Function
    End If

    startPos = InStr(cellText, "[") + 1
    endPos = InStr(cellText, "]")

    If startPos <> 0 And endPos <> 0 Then
        sheetName = Mid(cellText, startPos, endPos - startPos)
        Names.Add name:="JumpOrCreateSheetFromLink_PrevSheet", _
                  RefersTo:=ActiveSheet.name
    Else
        Application.StatusBar = "[L[]形式が必要です]"
        strResult = ""
    End If

    Set ws = SelectOrCreateWs(sheetName, ActiveWorkbook.name)  ' 関数を使いまわした都合で
    strResult = sheetName

    GetSheetName_JumpOrCreateSheetFromLink = strResult
End Function

Sub RenameLinkSheet(ByVal strOldName As String, ByVal strNewName As String)
    Dim strRenameSheetName As String
    Dim ws As Worksheet
    Dim foundCell As Range
    Dim firstAddress As String
    Dim keyword As String

    strRenameSheetName = strOldName
    keyword = "L[" & strRenameSheetName & "]"

    Application.DisplayAlerts = False
    ActiveWorkbook.Sheets(strRenameSheetName).name = strNewName
    Application.DisplayAlerts = True
    Application.StatusBar = strRenameSheetName & " => " & strNewName

    For Each ws In ActiveWorkbook.Sheets
        With ws.UsedRange
            Set foundCell = .Find(What:=keyword, LookIn:=xlValues, LookAt:=xlPart)
            If Not foundCell Is Nothing Then
                Do
                    If Trim(foundCell.Value) <> "" Then
                        foundCell.Value = "L[" & strNewName & "]"
                    End If
                    Set foundCell = .FindNext(foundCell)
                Loop While Not foundCell Is Nothing
            End If
        End With
    Next ws

End Sub

Sub DeleteLinkSheet()
    Dim strDeleteSheetName As String
    Dim ws As Worksheet
    Dim foundCell As Range
    Dim firstAddress As String
    Dim keyword As String

    strDeleteSheetName = ActiveSheet.name
    keyword = "L[" & strDeleteSheetName & "]"

    Dim answer As String
    answer = MsgBox("表示中のリンクシートを削除しますか？", vbYesNo + vbQuestion, "確認")

    If answer = vbYes Then
        Application.DisplayAlerts = False
        ActiveWorkbook.Sheets(strDeleteSheetName).Delete
        Application.DisplayAlerts = True
        Application.StatusBar = strDeleteSheetName & " を削除しました"

        For Each ws In ActiveWorkbook.Sheets
            With ws.UsedRange
                Set foundCell = .Find(What:=keyword, LookIn:=xlValues, LookAt:=xlPart)
                If Not foundCell Is Nothing Then
                    Do
                        If Trim(foundCell.Value) <> "" Then
                            foundCell.Value = ""
                        End If
                        Set foundCell = .FindNext(foundCell)
                    Loop While Not foundCell Is Nothing
                End If
            End With
        Next ws

    Else
        Application.StatusBar = "削除キャンセルしました"
    End If

End Sub

Sub RenameSheetAndUpdateLinks()

    Dim oldName As String
    Dim newName As String
    Dim ws As Worksheet
    Dim foundCell As Range
    Dim firstAddress As String
    Dim oldKeyword As String
    Dim newKeyword As String
    Dim chk As Worksheet

    oldName = ActiveSheet.name

    newName = InputBox("新しいシート名を入力してください", "シート名変更", oldName)

    If Trim(newName) = "" Then
        MsgBox "処理を中止しました"
        Exit Sub
    End If

    On Error Resume Next
    Set chk = Worksheets(newName)
    On Error GoTo 0

    If Not chk Is Nothing Then
        MsgBox "同じ名前のシートが既に存在します"
        Exit Sub
    End If

    oldKeyword = "L[" & oldName & "]"
    newKeyword = "L[" & newName & "]"

    Application.ScreenUpdating = False

    ActiveSheet.name = newName

    For Each ws In ActiveWorkbook.Worksheets
        With ws.UsedRange
            Set foundCell = .Find(What:=oldKeyword, LookIn:=xlValues, LookAt:=xlPart)

            If Not foundCell Is Nothing Then
                firstAddress = foundCell.Address

                Do
                    foundCell.Value = Replace(foundCell.Value, oldKeyword, newKeyword)

                    Set foundCell = .FindNext(foundCell)

                    If foundCell Is Nothing Then Exit Do
                Loop While foundCell.Address <> firstAddress
            End If
        End With
    Next ws

    Application.ScreenUpdating = True
    Application.StatusBar = oldName & " → " & newName & " に変更し、リンクを更新しました"

    MsgBox "完了しました"

End Sub
