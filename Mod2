' Mod_WS_SearchRow.bas
'==============================
'もし育てるなら次は:
'
'ヘッダー名キャッシュ (高速化)
'
'Dictionary化 (複数検索高速化)
'
'エラー管理統一
'
'クラス化 (KeyIndexオブジェクト化)
'



'==============================
' 指定列でキー一致行を返す
'==============================
Function fPg_searchRow( _
    inptKey As String, _
    inptBook As String, _
    inptSht As String, _
    Optional inptCol As Long = 1 _
) As Long

    Dim rCol As Range
    Dim vMatch As Variant

    On Error Resume Next

    With Workbooks(inptBook).Worksheets(inptSht)

        Set rCol = .Columns(inptCol)
        If rCol Is Nothing Then Exit Function

        vMatch = Application.match(inptKey, rCol, 0)

