    Optional inptBook As String = "" _
) As Long

    Dim WBNAME As String
    WBNAME = IIf(inptBook = "", ActiveWorkbook.name, inptBook)

    Dim rRow As Range
    Dim sMatchCol As Variant

    On Error Resume Next

    With Workbooks(WBNAME).Worksheets(inptSht)

        Set rRow = .Rows(1)
        If rRow Is Nothing Then Exit Function

        sMatchCol = Application.match(inptKey, rRow, 0)

        If Not IsError(sMatchCol) Then
            fPg_searchCol = CLng(sMatchCol)
        Else
            fPg_searchCol = 0
        End If

    End With

End Function

