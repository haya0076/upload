Sub RunMacroFromCell()

    Dim cell As Range
    Dim txt As String
    Dim funcName As String
    Dim argsStr As String
    Dim args() As String
    Dim argList() As Variant
    Dim i As Long
    
    Dim openBracket As Long, closeBracket As Long
    Dim openParen As Long, closeParen As Long
    
    For Each cell In Selection
        
        If IsError(cell.Value) Then GoTo NextCell
        
        txt = Trim(cell.Value)
        
        If Left(txt, 2) <> "M[" Then GoTo NextCell
        
        ' --- 位置取得 ---
        openBracket = InStr(txt, "[")
        closeBracket = InStr(txt, "]")
        openParen = InStr(txt, "(")
        closeParen = InStrRev(txt, ")")
        
        ' --- 関数名 ---
        funcName = Mid(txt, openBracket + 1, closeBracket - openBracket - 1)
        funcName = Trim(funcName)
        
        ' --- 引数あり ---
        If openParen > 0 And closeParen > openParen Then
            
            argsStr = Mid(txt, openParen + 1, closeParen - openParen - 1)
            
            If Trim(argsStr) <> "" Then
                
                ' splitterはここで統一（fCnvMと合わせる）
                args = Split(argsStr, gSplitter_MMC)
                
                ReDim argList(LBound(args) To UBound(args))
                
                For i = LBound(args) To UBound(args)
                    argList(i) = Trim(args(i))
                Next i
                
                Call RunWithArgs(funcName, argList)
                
            Else
                Application.Run funcName
            End If
            
        Else
            ' 引数なし
            Application.Run funcName
        End If
        
NextCell:
    Next cell

End Sub

Sub RunWithArgs(funcName As String, argList() As Variant)

    Select Case UBound(argList)
        Case 0: Application.Run funcName, argList(0)
        Case 1: Application.Run funcName, argList(0), argList(1)
        Case 2: Application.Run funcName, argList(0), argList(1), argList(2)
        Case 3: Application.Run funcName, argList(0), argList(1), argList(2), argList(3)
        Case 4: Application.Run funcName, argList(0), argList(1), argList(2), argList(3), argList(4)
        Case 5: Application.Run funcName, argList(0), argList(1), argList(2), argList(3), argList(4), argList(5)
        Case Else
            MsgBox "引数多すぎ: " & funcName
    End Select

End Sub
