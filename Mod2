' [DEF] 配列を文字結合
Function fTextJoin(inptDelimiter As String, inptArray As Variant) As String
    ' fTextJoin(", ", Array("a", "b", "c"))
    ' a, b, c
    fTextJoin = WorksheetFunction.TextJoin(inptDelimiter, True, inptArray)
End Function

Function fSplitBetween(ByVal src As String, _
                        ByVal startStr As String, _
                        ByVal endStr As String) As String
    Dim p1 As Long, p2 As Long

    p1 = InStr(src, startStr)
    If p1 = 0 Then Exit Function

    p1 = p1 + Len(startStr)
    p2 = InStr(p1, src, endStr)
    If p2 = 0 Then Exit Function

    fSplitBetween = Mid(src, p1, p2 - p1)
End Function

Public Function fsplit(ByVal txt As String, ByVal idx As Long, Optional ByVal splitter As String = ",") As String
    
    If txt = "" Then
        fsplit = ""
        Exit Function
    End If
    
    Dim arr As Variant
    
    ' 分割
    arr = Split(txt, splitter)
    
    ' 範囲チェック（0始まり）
    If idx < LBound(arr) Or idx > UBound(arr) Then
        fsplit = ""
        Exit Function
    End If
    
    ' 取得
    fsplit = arr(idx - 1)

End Function


Public Function fsplit_B(ByVal txt As String, ByVal idx As Long, Optional ByVal splitter As String = ",") As String
    
    If txt = "" Then
        fsplit_B = ""
        Exit Function
    End If
    
    Dim arr As Variant
    
    ' 分割
    arr = Split(txt, splitter)
    
    ' 範囲チェック（0始まり）
    If idx < LBound(arr) Or idx - 1 > UBound(arr) Then
        fsplit_B = "インデックスが有効範囲にありません"
        Exit Function
    End If
    
    ' 取得
    fsplit_B = arr(UBound(arr) - idx + 1)

End Function
