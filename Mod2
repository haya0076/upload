' ① 子階層から「非表示」
Public Sub Hidden_rows()

    Dim ws As Worksheet
    Dim r As Long, c As Long
    Dim parentCol As Long
    Dim startRow As Long, endRow As Long
    Dim i As Long

    If TypeName(Selection) <> "Range" Then Exit Sub

    Set ws = Selection.Worksheet
    r = Selection.row
    c = Selection.Column

    ' 左に親があるか確認
    If c = 1 Then
        MsgBox "親階層がありません", vbExclamation
        Exit Sub
    End If

    parentCol = c - 1

    ' 上方向に「親」を探す
    For i = r To 1 Step -1
        If ws.Cells(i, parentCol).Value <> "" Then
            startRow = i
            Exit For
        End If
    Next

    If startRow = 0 Then Exit Sub

    ' 次の親を探す
    endRow = ws.Rows.Count

    For i = startRow + 1 To ws.Rows.Count
        If ws.Cells(i, parentCol).Value <> "" Then
            endRow = i - 1
            Exit For
        End If
    Next

    ' 範囲非表示（親の次の行から）
    If endRow >= startRow + 1 Then
        ws.Rows((startRow + 1) & ":" & endRow).Hidden = True
    End If

    For i = c - 1 To c
        Call SetDoubleBorder(startRow, endRow, i)
    Next
 
     '装飾を追加
    Cells(startRow, c - 1).Value = gExpandLabel & Cells(startRow, c - 1)

End Sub


'② 親階層から「展開」
Public Sub Expand_rows()

    Dim ws As Worksheet
    Dim r As Long, c As Long
    Dim startRow As Long, endRow As Long
    Dim i As Long

    If TypeName(Selection) <> "Range" Then Exit Sub

    Set ws = Selection.Worksheet
    r = Selection.row
    c = Selection.Column

    ' 親行
    startRow = r

    ' 次の親を探す
    endRow = ws.Rows.Count

    For i = r + 1 To ws.Rows.Count
        If ws.Cells(i, c).Value <> "" Then
            endRow = i - 1
            Exit For
        End If
    Next

    ' 範囲表示
    If endRow >= startRow + 1 Then
        ws.Rows((startRow + 1) & ":" & endRow).Hidden = False
    End If

    For i = c To c + 1
        Call ClearDoubleBorder(startRow, endRow, i)
    Next
    
     '装飾を外す
    Cells(startRow, c).Value = Replace(Cells(startRow, c), gExpandLabel, "")
       

End Sub

Sub SetDoubleBorder(ByVal startRow As Long, ByVal endRow As Long, ByVal targetCol As Long)

    With ActiveSheet

        ' 親との境界（上側）
        With .Cells(startRow, targetCol).Borders(xlEdgeBottom)
            .LineStyle = xlDouble
            .Weight = xlMedium
        End With
        
    End With

End Sub

' [DEF] ボーダーのクリア
Sub ClearDoubleBorder(ByVal startRow As Long, ByVal endRow As Long, ByVal targetCol As Long)

    With ActiveSheet
        .Cells(startRow, targetCol).Borders(xlEdgeBottom).LineStyle = xlNone
    End With

End Sub









