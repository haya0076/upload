Public Function getA1(ByVal inptShtName As String) As String
    Dim sResult As String
    Dim sSheetName As String
    sSheetName = fSplitBetween(inptShtName, "L[", "]")
    If sSheetName = "" Then sSheetName = inptShtName
    
    If sSheetName = "" Then
        sResult = "-"
    ElseIf IsExistWs(sSheetName) = False Then
        sResult = "[シート未作成]"
    Else
        sResult = ActiveWorkbook.Sheets(sSheetName).Range("A1").Value
        If sResult = "" Then sResult = "-"
    End If
    getA1 = sResult
End Function


