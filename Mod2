' [DEF] 一行を上に移動する
Sub MoveRowUp()

    If TypeName(Selection) <> "Range" Then Exit Sub
    If Selection.Cells.Count <> 1 Then Exit Sub

    Dim ws As Worksheet
    Dim r As Long, c As Long

    Set ws = Selection.Worksheet
    r = Selection.row
    c = Selection.Column

    If r <= 1 Then Exit Sub

    ws.Rows(r).Cut
    ws.Rows(r - 1).Insert Shift:=xlDown
    ws.Cells(r - 1, c).Select

    Application.CutCopyMode = False

End Sub

' [DEF] 一行を下に移動する
Sub MoveRowDown()

    If TypeName(Selection) <> "Range" Then Exit Sub
    If Selection.Cells.Count <> 1 Then Exit Sub

    Dim ws As Worksheet
    Dim r As Long, c As Long

    Set ws = Selection.Worksheet
    r = Selection.row
    c = Selection.Column

    ws.Rows(r).Cut
    ws.Rows(r + 2).Insert Shift:=xlDown
    ws.Cells(r + 1, c).Select

    Application.CutCopyMode = False

End Sub

