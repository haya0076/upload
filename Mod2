'==============================
' メイン検索関数
'==============================

Function GetValueByKey( _
    sKey As String, _
    sWs As String, _
    Optional sKeyCol As String = "[KEY]", _
    Optional sRtnCol As String = "[VAL]", _
    Optional inptErr As String = "#VALUE!", _
    Optional inptBook As String = "" _
) As String

    Dim WBNAME As String
    WBNAME = IIf(inptBook = "", ActiveWorkbook.name, inptBook)

    ' 列名 → 列番号変換
    sKeyCol = ResolveColumn(sKeyCol, sWs, WBNAME)
    sRtnCol = ResolveColumn(sRtnCol, sWs, WBNAME)

    If sKeyCol = "" Or sRtnCol = "" Then
        GetValueByKey = inptErr
        Exit Function
    End If
    
    GetValueByKey = fGetCellData( _
        WBNAME, sWs, sKey, _
        CLng(sKeyCol), CLng(sRtnCol), _
        inptErr)

End Function


'==============================
' 列解決（重複除去ポイント）
'==============================

 Function ResolveColumn( _
    colSpec As String, _
    wsName As String, _
    WBNAME As String _
) As String

    If Left(colSpec, 1) = "[" Then
        ResolveColumn = fSearchField( _
            Mid(colSpec, 2, Len(colSpec) - 2), _
            wsName, WBNAME)
    Else
        ResolveColumn = Columns(colSpec).Column
    End If

End Function


'==============================
' 実データ取得
'==============================
 
 Function fGetCellData( _
    WBNAME As String, _
    wsName As String, _
    inptKey As String, _
    inptKeyCol As Long, _
    inptTargetCol As Long, _
    Optional inptErrMsg As String = "#VALUE!" _
) As String

    Dim rColKey As Range
    Dim sMatchRow As Variant

    On Error Resume Next

    With Workbooks(WBNAME).Worksheets(wsName)

        Set rColKey = .Columns(inptKeyCol)
        If rColKey Is Nothing Then
            fGetCellData = inptErrMsg
            Exit Function
        End If

        sMatchRow = Application.match(inptKey, rColKey, 0)

        If Not IsError(sMatchRow) Then
            fGetCellData = .Cells(CLng(sMatchRow), inptTargetCol).Value
        Else
            fGetCellData = inptErrMsg
        End If

    End With

End Function


