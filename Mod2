        If VarType(cell.Value) = vbString Then
            txt = cell.Value
            
            If Left(txt, 2) = "L[" And InStr(txt, "]") > 0 Then
                sheetName = Mid(txt, 3, InStr(txt, "]") - 3)
                
                If sheetName <> "" Then
                    moveList(sheetName) = True '重複排除
                End If
            End If
        End If
    Next

    If moveList.Count = 0 Then
        MsgBox "L[]が見つかりません"
        Exit Sub
    End If

    '========================
    '② 移動先ブック選択
    '========================
    filePath = Application.GetOpenFilename( _
        "Excelファイル (*.xlsx;*.xlsm), *.xlsx;*.xlsm", , "移動先ブックを選択")

    If filePath = False Then Exit Sub

    Set wbTarget = Workbooks.Open(filePath)

    '========================
    '③ シート移動
    '========================
    Dim key As Variant
    
    For Each key In moveList.Keys
        
        On Error Resume Next
        Set sh = wbSource.Sheets(key)
        On Error GoTo 0
        
        If Not sh Is Nothing Then
            
            '同名シートチェック（必要なら）
            If SheetExists(CStr(key), wbTarget) Then
                MsgBox "既に存在: " & key
            Else
                sh.Move After:=wbTarget.Sheets(wbTarget.Sheets.Count)
            End If
            
        Else
            MsgBox "存在しないシート: " & key
        End If
        
        Set sh = Nothing
    Next

    MsgBox "完了"

End Sub


