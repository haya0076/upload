Sub HighlightFromClipboard_Red()

    Dim clipText As String
    Dim c As Range
    Dim pos As Long

    clipText = GetClipboardText()
    If clipText = "" Then Exit Sub
    If TypeName(Selection) <> "Range" Then Exit Sub

    Application.ScreenUpdating = False

    For Each c In Selection.Cells
        If Not IsError(c.Value) Then
            pos = InStr(1, c.Value, clipText, vbBinaryCompare)
            Do While pos > 0
                With c.Characters(pos, Len(clipText)).Font
                    .Color = vbRed
                    .Bold = True
                End With
                pos = InStr(pos + Len(clipText), c.Value, clipText, vbBinaryCompare)
            Loop
        End If
    Next c

    Application.ScreenUpdating = True
End Sub


