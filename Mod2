' 再リンク
Public Sub LinkCellsToNameSheets()

    Dim ws As Worksheet
    Dim cell As Range
    Dim txt As String
    Dim sheetName As String
    Dim targetWs As Worksheet

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    On Error GoTo CleanFail

    For Each ws In ActiveWorkbook.Worksheets
        For Each cell In ws.UsedRange.Cells

            If Len(CStr(cell.Value)) > 0 Then
                txt = CStr(cell.Value)

                If Left(txt, 2) = "L[" And Right(txt, 1) = "]" Then
                    sheetName = Mid(txt, 3, Len(txt) - 3)

                    Set targetWs = Nothing
                    On Error Resume Next
                    Set targetWs = ActiveWorkbook.Worksheets(sheetName)
                    On Error GoTo 0

                    If Not targetWs Is Nothing Then

                        If cell.Hyperlinks.Count > 0 Then
                            cell.Hyperlinks.Delete
                        End If

                        cell.Value = cell.Value
                        cell.Font.ColorIndex = xlAutomatic
                        cell.Font.Underline = xlUnderlineStyleNone

                        ws.Hyperlinks.Add _
                            anchor:=cell, _
                            Address:="", _
                            SubAddress:="'" & targetWs.name & "'!A1", _
                            TextToDisplay:=txt

                    Else
                        Debug.Print "未リンク：シート [" & sheetName & "] が存在しません"
                    End If

                End If
            End If

        Next cell
    Next ws

    MsgBox "リンクの再作成完了"
    GoTo CleanExit

CleanFail:
    MsgBox "処理中にエラーが発生しました：" & Err.Description, vbExclamation

CleanExit:
    Application.EnableEvents = True
    Application.ScreenUpdating = True

End Sub

