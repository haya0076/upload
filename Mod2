Public Function GetClipboardText() As String
    Dim hMem As LongPtr
    Dim lpMem As LongPtr
    Dim length As Long
    Dim buffer As String

    If OpenClipboard(0&) = 0 Then Exit Function

    hMem = GetClipboardData(CF_UNICODETEXT)
    If hMem <> 0 Then
        lpMem = GlobalLock(hMem)
        If lpMem <> 0 Then
            length = lstrlenW(lpMem)
            buffer = String$(length, vbNullChar)
            CopyMemory StrPtr(buffer), lpMem, length * 2
            GlobalUnlock hMem
            GetClipboardText = buffer
        End If
    End If

    CloseClipboard
End Function


' TOGGLE WINDOW ===================================================================
Sub ToggleTopMode()

    If gIsUIMode = False Then
        AlwaysOnTop_ON
        gIsUIMode = True
    Else
        AlwaysOnTop_OFF
        gIsUIMode = False
    End If

End Sub

Sub AlwaysOnTop_ON()

    Dim hWnd As LongPtr
    hWnd = Application.hWnd

    SetWindowPos hWnd, HWND_TOPMOST, 0, 0, 0, 0, _
        SWP_NOMOVE Or SWP_NOSIZE

End Sub

Sub AlwaysOnTop_OFF()

    Dim hWnd As LongPtr
    hWnd = Application.hWnd

    SetWindowPos hWnd, HWND_NOTOPMOST, 0, 0, 0, 0, _
        SWP_NOMOVE Or SWP_NOSIZE

End Sub



