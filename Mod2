Public Sub RenameSheetsAndReplaceText(Optional ByVal strRng As String = "")
    Dim wsActive As Worksheet
    Set wsActive = ActiveSheet

    Dim rngSel As Range
    Set rngSel = Selection
    If strRng <> "" Then Set rngSel = Range(strRng)

    If rngSel.Columns.Count < 2 Then
        MsgBox "2列（旧名 / 新名）を選択してください"
        Exit Sub
    End If

    Dim r As Long
    Dim prevSheet As Worksheet
    Set prevSheet = wsActive   ' ← 基準：マクロを実行したシート

    For r = 1 To rngSel.Rows.Count
        Dim wsTarget As Worksheet

        ' 既存処理（名前変更など）
        Set wsTarget = ProcessOneRow(wsActive, rngSel, r)

        ' 並び替え：前のシートの後ろへ
        If Not wsTarget Is Nothing Then
            wsTarget.Move After:=prevSheet
            Set prevSheet = wsTarget
        End If
    Next r

    wsActive.Activate
End Sub

