Sub AppendGroup(outNo As Integer, folderPath As String, isEntry As Boolean)

    Dim fileName As String
    
    fileName = Dir(folderPath & "*.bas")
    
    Do While fileName <> ""
        
        If IsEntryFile(fileName) = isEntry Then
            Call AppendFile(outNo, folderPath, fileName)
        End If
        
        fileName = Dir
        
    Loop

End Sub

Function IsEntryFile(fileName As String) As Boolean

    If fileName = "Entry_Config.bas" _
    Or fileName = "Entry_Const.bas" _
    Or fileName = "Entry_KeyBind.bas" _
    Or fileName = "Entry_Main.bas" Then
    
        IsEntryFile = True
        
    End If

End Function


Sub AppendFile(outNo As Integer, folderPath As String, fileName As String)

    Dim fileNo As Integer
    Dim lineText As String
    
    fileNo = FreeFile
    
    Open folderPath & fileName For Input As #fileNo
    
    Print #outNo, "'--- " & fileName & " ---"
    
    Do Until EOF(fileNo)
        
        Line Input #fileNo, lineText
        
        ' 除外
        If Left(lineText, 17) = "Attribute VB_Name" Then GoTo ContinueLoop
        If Trim(lineText) = "" Then GoTo ContinueLoop
        
        Print #outNo, lineText
        
ContinueLoop:
    Loop
    
    Close #fileNo
    
    Print #outNo, vbCrLf

End Sub








