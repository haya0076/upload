    Application.OnKey "+^%{DOWN}"
    Application.OnKey "+^%{UP}"
    Application.OnKey "+^%{LEFT}"
    Application.OnKey "+^%{RIGHT}"
    
    Application.OnKey "+^{DOWN}"
    Application.OnKey "+^{UP}"
    Application.OnKey "+^{LEFT}"
    Application.OnKey "+^{RIGHT}"
    
    Application.OnKey "+^%n"
    Application.OnKey "^n"
