' [DEF] 設定されたマクロ参照ワークブックを取得
Public Function p_wbName_main()
    '設定されていない場合
    If GetCrrBookName = "" Then Stop
    '現在のブック名と作業中のブック名が異なる
    If GetCrrBookName <> ActiveWorkbook.name Then Stop
    p_wbName_main = GetCrrBookName
End Function

' [DEF] XLMA ブックを取得
Public Function p_wbName_ma()
    p_wbName_ma = ThisWorkbook.name
End Function

' [DEF]
Sub SetCrrSht()
    Names.Add name:="CurrentSheetName", RefersTo:=ActiveSheet.name
    Application.StatusBar = "シート名をセット : " & ActiveSheet.name
End Sub

Sub SelectCrrSht()
    ActiveWorkbook.Sheets(Evaluate("CurrentSheetName")).Select
End Sub

' [DEF] 現在のブック名を設定
Sub SetCrrBookName()
    Names.Add name:="CurrentBookName", RefersTo:=ActiveWorkbook.name
    Application.StatusBar = "ブック名をセット : " & ActiveWorkbook.name
End Sub

' [DEF] 現在のブック名を取得
Function GetCrrBookName() As String
    If Evaluate("CurrentBookName") = "" Then Call SetCrrBookName
    GetCrrBookName = Evaluate("CurrentBookName")
End Function

' [DEF] 設定中のワークブックのフルパスを取得
Function GetTargetWb_FullPath() As String
    GetTargetWb_FullPath = Workbooks(p_wbName_main()).Path & "\" & Workbooks(p_wbName_main()).name
End Function

' [DEF] 設定中のワークブック名を取得
Function GetTargetWb_Name() As String
    GetTargetWb_Name = GetCrrBookName
    ' #TODO : [確認] 廃止
    ' Workbooks(p_wbName_main()).Name
End Function



