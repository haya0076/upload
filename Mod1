Sub load_kb_util()
    Application.OnKey "^u", "ToggleUIMode"
    Application.OnKey "^t", "ToggleTopMode"
End Sub

Sub load_kb_SetParam()
    Application.OnKey "+^%b", "SetCrrBookName"
    Application.OnKey "+^%s", "SetCrrSht"
    Application.OnKey "+^%h", "SelectCrrSht"
End Sub

Sub load_kb_Window()
    Application.OnKey "+^%n", "OpenNewWindow"
End Sub

Sub load_kb_rowExpand()
    Application.OnKey "^+h", "Hidden_rows"
    Application.OnKey "^+e", "Expand_rows"
End Sub

Sub load_kb_color()
'    Application.OnKey "^+%u", "UnderlineBottomOfSelection" ' 下線を引く
    Application.OnKey "^+r", "SetRedBold"
    Application.OnKey "^+b", "SetBlueBold"
    Application.OnKey "+^c", "ResetFont" ' 選択行の装飾を解除する
    Application.OnKey "^r", "HighlightFromClipboard_Red" ' 選択範囲内に含まれるクリップボードの文字を赤太文字にする
End Sub



' [DEF] シート管理、L[] シート操作
Sub load_kb_LinkSht()
    Application.OnKey "+^%u", "RenameSheetAndUpdateLinks"
    Application.OnKey "+^%d", "DeleteLinkSheet"
    Application.OnKey "+^%m", "JumpOrCreateSheetFromLink_Move"
    Application.OnKey "+^%o", "JumpOrCreateSheetFromLink_Open"
End Sub


' [DEF] シート操作
Sub load_kb_EditRange()
    Application.OnKey "+%{DOWN}", "InsertRange_Down"
    Application.OnKey "+%{RIGHT}", "InsertRange_Right"
    Application.OnKey "+%{LEFT}", "InsertRange_Left"
    Application.OnKey "+%{UP}", "InsertRange_Up"
    
    Application.OnKey "+^%{DOWN}", "InsertRow_Down"
    Application.OnKey "+^%{UP}", "InsertRow_Up"
    Application.OnKey "+^%{LEFT}", "InsertCol_Left"
    Application.OnKey "+^%{RIGHT}", "InsertCol_Right"
    
    Application.OnKey "%{UP}", "MoveRowUp"     ' Alt + ↑
    Application.OnKey "%{DOWN}", "MoveRowDown" ' Alt + ↓
    
    Application.OnKey "+^a", "Calc"
        
        
    ' 動作未確認
'    Application.OnKey "+%n", "Pg_NextPage"
'    Application.OnKey "+%p", "Pg_PrevPage"
    
    Application.OnKey "^p", "fPasteSpecial"
    Application.OnKey "+%s", "SortSheetsByName"
    Application.OnKey "+%h", "HideEmptyRowsBetweenData"


End Sub



